{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Bun Tests",
      "type": "bun",
      "request": "launch",
      "program": "bun",
      "runtime": "bun",
      "args": ["test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Bun Server",
      "type": "bun",
      "request": "launch",
      "runtime": "bun",
      "program": "${workspaceFolder}/src/server.ts",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
